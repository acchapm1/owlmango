{
  "buffer_font_weight": 400.0,
  "agent_buffer_font_size": 14.5,
  "agent_servers": {
    "codex": {
      "default_mode": "read-only",
    },
    "opencode": {
      "type": "extension",
      "favorite_models": ["openai/gpt-5.2-codex"],
      "default_config_options": {},
      "favorite_config_option_values": {},
    },
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Mocha",
    "dark": "Catppuccin Mocha",
  },
  "experimental.theme_overrides": {
    "syntax": {
      "comment": {
        "font_style": "italic",
      },
    },
  },
  "title_bar": {
    "show_user_picture": false,
  },
  "agent": {
    "show_turn_stats": true,
    "use_modifier_to_send": false,
    "default_profile": "ask",
    "always_allow_tool_actions": true,
    "profiles": {
      "chat": {
        "name": "chat",
        "tools": {
          "copy_path": true,
          "create_directory": true,
          "create_file": true,
          "delete_path": true,
          "diagnostics": true,
          "edit_file": true,
          "fetch": true,
          "list_directory": true,
          "move_path": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "grep": true,
          "terminal": true,
          "thinking": true,
          "web_search": true,
          "open": false,
        },
        "enable_all_context_servers": true,
        "context_servers": {},
      },
      "write": {
        "name": "Write",
        "tools": {
          "copy_path": true,
          "create_directory": true,
          "create_file": true,
          "delete_path": true,
          "diagnostics": true,
          "edit_file": true,
          "fetch": true,
          "list_directory": true,
          "move_path": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "grep": true,
          "terminal": true,
          "thinking": true,
          "web_search": true,
          "open": false,
        },
        "enable_all_context_servers": true,
        "context_servers": {},
      },
    },
    "model_parameters": [],
    "default_model": {
      "provider": "zed.dev",
      "model": "gpt-5.2-codex",
    },
  },
  "language_models": {
    "ollama": {
      "available_models": [
        {
          "name": "mistral-nemo:12b",
          "display_name": "Mistral Nemo (128k)",
          "max_tokens": 131072,
        },
        {
          "name": "llama3.1:8b",
          "display_name": "LLama 3.1",
          "max_tokens": 65535,
          "supports_tools": true,
        },
        {
          "name": "deepseek-r1:8b",
          "display_name": "Deepseek (8B)",
          "max_tokens": 65535,
          "supports_tools": true,
        },
      ],
    },
  },
  "edit_predictions": {
    "provider": "zed",
    "disabled_globs": [],
    "mode": "eager",
  },
  "telemetry": {
    "metrics": false,
  },
  "auto_install_extensions": {
    "adwaita-pastel": true,
    "docker-compose": true,
    "dockerfile": true,
    "emmet": true,
    "fish": true,
    "git-firefly": true,
    "html": true,
    "log": true,
    "make": true,
    "markdown-oxide": true,
    "ruby": true,
    "scss": true,
    "slim": true,
    "sql": true,
    "svelte": true,
    "terraform": true,
    "xml": true,
    "catppuccin-icons": true,
    "kanagawa-themes": true,
  },
  "vim_mode": true,
  "theme": {
    "mode": "system",
    "light": "Kanagawa Lotus",
    "dark": "Adwaita Pastel Dark",
  },
  "buffer_font_size": 14.5,
  "buffer_font_family": "Adwaita Mono",
  "buffer_font_fallbacks": ["Adwaita Mono"],
  "buffer_line_height": "comfortable",
  "ui_font_size": 16.5,
  "ui_font_family": "Adwaita Sans",
  "ui_font_weight": 400,
  "restore_on_startup": "empty_tab",
  "cursor_blink": false,
  "current_line_highlight": "gutter",
  "wrap_guides": [80, 120],
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "selections_menu": false,
  },
  "project_panel": {
    "button": true,
    "dock": "left",
    "scrollbar": {
      "show": "always",
    },
    "hide_hidden": true,
  },
  "outline_panel": {
    "button": false,
    "scrollbar": {
      "show": "always",
    },
  },
  "tab_size": 2,
  "soft_wrap": "none",
  "auto_update": true,
  "load_direnv": "direct",
  "scrollbar": {
    "show": "system",
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show": true,
    "show_tab_bar_buttons": false,
  },
  "tabs": {
    "file_icons": true,
    "show_diagnostics": "errors",
    "show_close_button": "always",
    "git_status": true,
  },
  "git": {
    "inline_blame": {
      "enabled": true,
      "delay_ms": 500,
      "show_commit_summary": true,
      "padding": 8,
    },
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
    "background_coloring": "disabled",
    "active_line_width": 2,
  },
  "show_whitespaces": "none",
  "terminal": {
    "scrollbar": {
      "show": "auto",
    },
    "font_family": "Adwaita Mono",
    "font_size": 16.5,
    "alternate_scroll": "on",
    "line_height": "comfortable",
    "button": false,
    "blinking": "off",
  },
  "collaboration_panel": {
    "button": false,
  },
  "file_types": {
    "YAML": ["Klusterfile", "*.yaml.j2", "*.yml.j2", "*.yaml.erb", "*.yml.erb"],
    "Shell Script": [
      "secrets",
      "secrets.staging",
      "secrets.demo",
      "secrets.production",
    ],
    "SCSS": ["*.css"],
    "Dockerfile": ["Dockerfile.*"],
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/node_modules",
    "**/log",
    "**/logs",
    "**/tmp",
    "**/tmpfiles",
    "**/dist",
    "**/out",
    "**/__pycache__",
    "**/*.pyc",
    "**/*.pyo",
    "**/*.class",
    "**/*.log",
    "**/*.tmp",
    ".direnv",
    "vendor/**",
    "*.egg-info",
    "mise.toml",
    "*.lock",
    ".ruby-lsp/**",
    ".bundle",
    ".kamal",
    "!.solargraph.yml",
    "**/terraform.tfstate*",
    "**/bun.lockb",
    "**/target",
    "**/build",
    "**/app/assets/builds",
    "coverage/**",
    "**/.idea",
    "**/.vscode",
    "**/.cache",
    "**/.pytest_cache",
    "**/.mypy_cache",
    "**/.tox",
    "**/.coverage",
    "**/.history",
    "**/*.swp",
    "**/*.swo",
    "**/.gradle",
    "**/obj",
    "**/debug",
    "resources/**/*.ui",
    "vendor/gems/**",
    "bun.lock",
    "go.mod",
    "go.sum",
    ".venv",
  ],
  "prettier": {
    "enabled": true,
    "options": {
      "tabWidth": 2,
      "useTabs": false,
      "semi": true,
      "singleQuote": false,
      "trailingComma": "all",
      "bracketSpacing": true,
      "jsxBracketSameLine": false,
      "arrowParens": "always",
      "printWidth": 80,
    },
  },
  "format_on_save": "on",
  "languages": {
    "YAML": {
      "tab_size": 2,
      "hard_tabs": false,
      "format_on_save": "off",
    },
    "Markdown": {
      "remove_trailing_whitespace_on_save": false,
    },
    "Rust": {
      "tab_size": 2,
    },
    "Ruby": {
      "language_servers": [
        "ruby-lsp",
        "!rubocop",
        "!solargraph",
        "!sorbet",
        "!steep",
        "...",
      ],
      "formatter": {
        "external": {
          "command": "bundle",
          "arguments": [
            "exec",
            "rubocop",
            "--fail-level",
            "error",
            "-A",
            "--stdin",
            "corrected.rb",
            "--stderr",
          ],
        },
      },
    },
  },
  "lsp": {
    "ruby-lsp": {
      "initialization_options": {
        "enabledFeatures": {
          "diagnostics": false,
          "formatting": false,
        },
      },
    },
    "solargraph": {
      "initialization_options": {
        "diagnostics": true,
        "formatting": false,
      },
    },
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "buildScripts": {
            "enable": true,
          },
        },
      },
    },
  },
  "always_treat_brackets_as_autoclosed": true,
  "inlay_hints": {
    "enabled": true,
  },
  "journal": {
    "hour_format": "hour24",
  },
  "preview_tabs": {
    "enabled": false,
  },
  "file_finder": {
    "modal_max_width": "small",
  },
  "show_call_status_icon": false,
}
