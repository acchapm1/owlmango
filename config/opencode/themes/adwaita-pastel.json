{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg_dark": "#1e1e1e",
    "panel_dark": "#303030",
    "element_dark": "#444444",
    "border_dark": "#4f4f4f",
    "text_dark": "#ffffff",
    "text_muted_dark": "#c7c7c7",
    "text_dim_dark": "#808080",
    "accent_dark": "#62a0ea",
    "accent2_dark": "#0ab9dc",
    "primary_dark": "#62a0ea",

    "bg_light": "#ffffff",
    "panel_light": "#fafafa",
    "element_light": "#ebebeb",
    "border_light": "#e1e1e1",
    "text_light": "#2f2f2f",
    "text_muted_light": "#5f5f5f",
    "text_dim_light": "#808080",
    "accent_light": "#99c1f1",
    "accent2_light": "#04a5e5",

    "err_dark": "#ed333b",
    "err_light": "#c01c28",
    "warn_dark": "#f8e45c",
    "warn_light": "#f5c211",
    "ok_dark": "#57e389",
    "ok_light": "#2ec27e",
    "info_dark": "#62a0ea",
    "info_light": "#1c71d8",

    "branch_dark": "#585b70",
    "branch_light": "#6c6f85",

    "diff_add_bg_dark": "#203b2c",
    "diff_del_bg_dark": "#3b2020",
    "diff_ctx_bg_dark": "#303030",
    "diff_add_bg_light": "#e6f6ea",
    "diff_del_bg_light": "#fde8e8",
    "diff_ctx_bg_light": "#fafafa"
  },
  "theme": {
    "primary": { "dark": "primary_dark", "light": "info_light" },
    "secondary": { "dark": "accent2_dark", "light": "accent2_light" },
    "accent": { "dark": "primary_dark", "light": "info_light" },

    "error": { "dark": "err_dark", "light": "err_light" },
    "warning": { "dark": "warn_dark", "light": "warn_light" },
    "success": { "dark": "ok_dark", "light": "ok_light" },
    "info": { "dark": "info_dark", "light": "info_light" },

    "text": { "dark": "text_dark", "light": "text_light" },
    "textMuted": { "dark": "text_muted_dark", "light": "text_muted_light" },

    "background": { "dark": "bg_dark", "light": "bg_light" },
    "backgroundPanel": { "dark": "panel_dark", "light": "panel_light" },
    "backgroundElement": { "dark": "element_dark", "light": "element_light" },

    "border": { "dark": "border_dark", "light": "border_light" },
    "borderActive": { "dark": "accent_dark", "light": "accent_light" },
    "borderSubtle": { "dark": "panel_dark", "light": "element_light" },

    "diffAdded": { "dark": "ok_dark", "light": "ok_light" },
    "diffRemoved": { "dark": "err_dark", "light": "err_light" },
    "diffContext": { "dark": "text_dim_dark", "light": "text_dim_light" },
    "diffHunkHeader": { "dark": "text_muted_dark", "light": "text_muted_light" },
    "diffHighlightAdded": { "dark": "ok_dark", "light": "ok_light" },
    "diffHighlightRemoved": { "dark": "err_dark", "light": "err_light" },
    "diffAddedBg": { "dark": "diff_add_bg_dark", "light": "diff_add_bg_light" },
    "diffRemovedBg": { "dark": "diff_del_bg_dark", "light": "diff_del_bg_light" },
    "diffContextBg": { "dark": "diff_ctx_bg_dark", "light": "diff_ctx_bg_light" },
    "diffLineNumber": { "dark": "text_dim_dark", "light": "text_dim_light" },
    "diffAddedLineNumberBg": { "dark": "diff_add_bg_dark", "light": "diff_add_bg_light" },
    "diffRemovedLineNumberBg": { "dark": "diff_del_bg_dark", "light": "diff_del_bg_light" },

    "markdownText": { "dark": "text_dark", "light": "text_light" },
    "markdownHeading": { "dark": "text_dark", "light": "text_light" },
    "markdownLink": { "dark": "accent2_dark", "light": "info_light" },
    "markdownLinkText": { "dark": "accent2_dark", "light": "info_light" },
    "markdownCode": { "dark": "branch_dark", "light": "branch_light" },
    "markdownBlockQuote": { "dark": "text_muted_dark", "light": "text_muted_light" },
    "markdownEmph": { "dark": "text_dark", "light": "text_light" },
    "markdownStrong": { "dark": "text_dark", "light": "text_light" },
    "markdownHorizontalRule": { "dark": "border_dark", "light": "border_light" },
    "markdownListItem": { "dark": "text_dark", "light": "text_light" },
    "markdownListEnumeration": { "dark": "text_muted_dark", "light": "text_muted_light" },
    "markdownImage": { "dark": "text_muted_dark", "light": "text_muted_light" },
    "markdownImageText": { "dark": "text_muted_dark", "light": "text_muted_light" },
    "markdownCodeBlock": { "dark": "text_dark", "light": "text_light" },

    "syntaxComment": { "dark": "branch_dark", "light": "#8c8fa1" },
    "syntaxKeyword": { "dark": "#cba6f7", "light": "#8839ef" },
    "syntaxFunction": { "dark": "#89b4fa", "light": "#1e66f5" },
    "syntaxVariable": { "dark": "#cdd6f4", "light": "#4c4f69" },
    "syntaxString": { "dark": "#a6e3a1", "light": "#40a02b" },
    "syntaxNumber": { "dark": "#fab387", "light": "#fe640b" },
    "syntaxType": { "dark": "#f9e2af", "light": "#df8e1d" },
    "syntaxOperator": { "dark": "#89dceb", "light": "#04a5e5" },
    "syntaxPunctuation": { "dark": "#9399b2", "light": "#7c7f93" }
  }
}
