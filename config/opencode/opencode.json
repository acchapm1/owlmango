{
  "$schema": "https://opencode.ai/config.json",
  "theme": "adwaita-pastel",
  "agent": {
    "build": {
      "color": "#62a0ea"
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen2.5-coder:7b": { "name": "Qwen2.5 Coder 7B" },
        "qwen2.5-coder:14b": { "name": "Qwen2.5 Coder 14B" },
        "deepseek-coder-v2:16b": { "name": "DeepSeek Coder V2 16B" },
        "qwen2.5-coder:32b": { "name": "Qwen2.5 Coder 32B" },
        "llama3.1:8b-instruct-q8_0": { "name": "Llama 3.1 8B Instruct" },
        "llama3.1:70b-instruct": { "name": "Llama 3.1 70B Instruct" },
        "llama3.2:3b-instruct": { "name": "Llama 3.2 3B Instruct" }
      }
    }
  },
  "permission": {
    "skill": "allow",
    "todowrite": "allow",
    "edit": "allow",
    "bash": {
      "git": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "cargo": "allow",
      "cargo fmt": "allow",
      "cargo clippy": "allow",
      "cargo test": "allow",
      "ls": "allow",
      "find": "allow",
      "rg": "allow",
      "grep": "allow",
      "cargo llvm-cov": "allow",
      "which": "allow",
      "*": "ask"
    }
  }
}
