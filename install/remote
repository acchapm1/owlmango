#!/usr/bin/env bash
set -euo pipefail

# Remote bootstrap script for dotfiles installation
# Connects to a remote host via SSH and installs CLI-only configuration

VERSION="1.0.0"
REPO_URL="${DOTFILES_REPO_URL:-https://github.com/acchapm1/owlmango}"
INSTALL_DIR_RELATIVE=".local/share/owlmango"  # Relative to remote user's $HOME
INSTALL_DIR=""  # Will be set via -d flag or inferred remotely

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

log() {
    echo -e "${BLUE}==>${NC} $*"
}

success() {
    echo -e "${GREEN}✓${NC} $*"
}

error() {
    echo -e "${RED}✗${NC} $*" >&2
}

warn() {
    echo -e "${YELLOW}!${NC} $*"
}

usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS] [USER@]HOST

Remote bootstrap script for dotfiles installation.
Connects to a remote host via SSH and installs CLI-only configuration.

Arguments:
  [USER@]HOST         SSH destination (e.g., user@example.com or server.local)

Options:
  -r, --repo URL      Git repository URL (default: $REPO_URL)
  -d, --dir PATH      Installation directory on remote (default: \$HOME/$INSTALL_DIR_RELATIVE)
  -p, --port PORT     SSH port (default: 22)
  -i, --identity FILE SSH identity file (private key)
  -n, --dry-run       Show commands without executing
  -v, --verbose       Verbose output
  -h, --help          Show this help message

Environment Variables:
  DOTFILES_REPO_URL   Default repository URL
  SSH_AUTH_SOCK       SSH agent socket (for key forwarding)

Examples:
  # Basic usage
  $(basename "$0") user@server.example.com

  # With custom SSH port
  $(basename "$0") -p 2222 user@server.local

  # With SSH key
  $(basename "$0") -i ~/.ssh/id_rsa user@192.168.1.100

  # With custom repo
  $(basename "$0") -r https://github.com/myuser/dotfiles.git server

  # Dry run to see what would be executed
  $(basename "$0") --dry-run user@server

Note:
  - Installation is always CLI-only (--cli-only flag)
  - Requires git to be installed on the remote host
  - SSH key forwarding is recommended for private repos
EOF
}

# Parse arguments
SSH_HOST=""
SSH_PORT="22"
SSH_IDENTITY=""
DRY_RUN=0
VERBOSE=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        -r|--repo)
            REPO_URL="$2"
            shift 2
            ;;
        -d|--dir)
            INSTALL_DIR="$2"
            shift 2
            ;;
        -p|--port)
            SSH_PORT="$2"
            shift 2
            ;;
        -i|--identity)
            SSH_IDENTITY="$2"
            shift 2
            ;;
        -n|--dry-run)
            DRY_RUN=1
            shift
            ;;
        -v|--verbose)
            VERBOSE=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        -*)
            error "Unknown option: $1"
            usage
            exit 1
            ;;
        *)
            if [[ -z "$SSH_HOST" ]]; then
                SSH_HOST="$1"
            else
                error "Multiple hosts specified: $SSH_HOST and $1"
                exit 1
            fi
            shift
            ;;
    esac
done

# Validate arguments
if [[ -z "$SSH_HOST" ]]; then
    error "No SSH host specified"
    usage
    exit 1
fi

# Build SSH command
SSH_CMD="ssh"
SSH_OPTS=()

if [[ -n "$SSH_PORT" ]] && [[ "$SSH_PORT" != "22" ]]; then
    SSH_OPTS+=("-p" "$SSH_PORT")
fi

if [[ -n "$SSH_IDENTITY" ]]; then
    if [[ ! -f "$SSH_IDENTITY" ]]; then
        error "SSH identity file not found: $SSH_IDENTITY"
        exit 1
    fi
    SSH_OPTS+=("-i" "$SSH_IDENTITY")
fi

# Enable SSH agent forwarding for private repos
SSH_OPTS+=("-A")

# Verbose SSH
if [[ $VERBOSE -eq 1 ]]; then
    SSH_OPTS+=("-v")
fi

# Build the remote installation script
read -r -d '' REMOTE_SCRIPT <<'SCRIPT' || true
set -euo pipefail

log() { echo -e "\033[0;34m==>\033[0m $*"; }
success() { echo -e "\033[0;32m✓\033[0m $*"; }
error() { echo -e "\033[0;31m✗\033[0m $*" >&2; }

REPO_URL="__REPO_URL__"
INSTALL_DIR_RELATIVE="__INSTALL_DIR_RELATIVE__"

# Infer install directory from remote user's $HOME if not explicitly set
if [[ -z "${INSTALL_DIR:-}" ]]; then
    INSTALL_DIR="$HOME/$INSTALL_DIR_RELATIVE"
fi

log "Starting dotfiles installation on $(hostname)"
log "Install directory: $INSTALL_DIR"

# Detect package manager
PKG_MANAGER=""
INSTALL_CMD=""
UPDATE_CMD=""

if command -v apt-get >/dev/null 2>&1; then
    PKG_MANAGER="apt"
    INSTALL_CMD="sudo DEBIAN_FRONTEND=noninteractive apt-get install -y"
    UPDATE_CMD="sudo apt-get update"
elif command -v pacman >/dev/null 2>&1; then
    PKG_MANAGER="pacman"
    INSTALL_CMD="sudo pacman -S --needed --noconfirm"
    UPDATE_CMD="sudo pacman -Sy"
elif command -v yum >/dev/null 2>&1; then
    PKG_MANAGER="yum"
    INSTALL_CMD="sudo yum install -y"
    UPDATE_CMD="sudo yum check-update || true"
elif command -v dnf >/dev/null 2>&1; then
    PKG_MANAGER="dnf"
    INSTALL_CMD="sudo dnf install -y"
    UPDATE_CMD="sudo dnf check-update || true"
else
    error "No supported package manager found (apt, pacman, yum, dnf)"
    error "Please install git and fish manually, then re-run this script"
    exit 1
fi

log "Detected package manager: $PKG_MANAGER"

# Install essential packages if missing
log "Checking for essential packages..."

# Function to install a package from distro repos
install_package() {
    local pkg_name="$1"
    local cmd_name="${2:-$pkg_name}"
    
    if command -v "$cmd_name" >/dev/null 2>&1; then
        log "$cmd_name is already installed"
        return 0
    fi
    
    log "Installing $pkg_name..."
    if $INSTALL_CMD "$pkg_name" >/dev/null 2>&1; then
        success "$pkg_name installed"
        return 0
    else
        return 1
    fi
}


# Update package database
log "Updating package database..."
$UPDATE_CMD >/dev/null 2>&1 || true

# Install git (required for cloning repo)
if ! install_package git git; then
    error "Failed to install git - cannot continue"
    exit 1
fi

# Install fish (critical for this dotfiles setup)
fish_installed=0
if [[ "$PKG_MANAGER" == "apt" ]]; then
    if install_package fish fish; then
        fish_installed=1
    fi
elif [[ "$PKG_MANAGER" == "pacman" ]]; then
    if install_package fish fish; then
        fish_installed=1
    fi
elif [[ "$PKG_MANAGER" == "yum" ]] || [[ "$PKG_MANAGER" == "dnf" ]]; then
    if install_package fish fish; then
        fish_installed=1
    fi
fi

# Require distro packages for fish
if [[ $fish_installed -eq 0 ]]; then
    error "Failed to install fish from distro packages"
    error "Please install fish manually and re-run this script"
    exit 1
fi

# Install other useful packages (non-critical, so we don't fail if they're not available)
install_package curl curl || log "Note: curl installation failed (not critical)"
install_package wget wget || log "Note: wget installation failed (not critical)"

success "All essential packages installed"

# Clone or update repository
if [[ -d "$INSTALL_DIR/.git" ]]; then
    log "Updating existing repository at $INSTALL_DIR"
    cd "$INSTALL_DIR"
    git fetch origin
    git reset --hard origin/main || git reset --hard origin/master
    success "Repository updated"
else
    log "Cloning repository from $REPO_URL"
    mkdir -p "$(dirname "$INSTALL_DIR")"
    git clone "$REPO_URL" "$INSTALL_DIR"
    success "Repository cloned"
fi

# Run installation
log "Running installation with --cli-only flag"
cd "$INSTALL_DIR"

if [[ ! -x "install/local" ]]; then
    error "Installation script not found or not executable: install/local"
    exit 1
fi

bash install/local --cli-only

# owlmango keeps bash as the default login shell. fish and nushell are
# installed and available to opt into, but neither is forced via chsh.
if command -v fish >/dev/null 2>&1; then
    success "fish installed at $(command -v fish) (available via: exec fish)"
fi
if command -v nu >/dev/null 2>&1; then
    success "nushell installed at $(command -v nu) (available via: exec nu)"
fi
log "Default login shell left as bash for $USER and root (owlmango default)"

success "Installation complete!"
log "Next steps: logout and login again to pick up the new configuration"
SCRIPT

# Replace placeholders
REMOTE_SCRIPT="${REMOTE_SCRIPT//__REPO_URL__/$REPO_URL}"
REMOTE_SCRIPT="${REMOTE_SCRIPT//__INSTALL_DIR_RELATIVE__/$INSTALL_DIR_RELATIVE}"

# If custom install dir was specified, export it for the remote script
if [[ -n "$INSTALL_DIR" ]]; then
    REMOTE_SCRIPT="INSTALL_DIR=\"$INSTALL_DIR\"
$REMOTE_SCRIPT"
fi

# Display configuration
log "Remote Bootstrap Configuration"
echo "  Host:       $SSH_HOST"
echo "  Port:       $SSH_PORT"
echo "  Repository: $REPO_URL"
if [[ -n "$INSTALL_DIR" ]]; then
    echo "  Install to: $INSTALL_DIR"
else
    echo "  Install to: \$HOME/$INSTALL_DIR_RELATIVE (inferred remotely)"
fi
if [[ -n "$SSH_IDENTITY" ]]; then
    echo "  SSH Key:    $SSH_IDENTITY"
fi
echo ""

# Dry run
if [[ $DRY_RUN -eq 1 ]]; then
    warn "Dry run mode - no changes will be made"
    echo ""
    echo "Would execute over SSH:"
    echo "----------------------------------------"
    echo "$REMOTE_SCRIPT"
    echo "----------------------------------------"
    exit 0
fi

# Execute remote installation
log "Connecting to $SSH_HOST..."

if $SSH_CMD "${SSH_OPTS[@]}" "$SSH_HOST" bash <<EOF
$REMOTE_SCRIPT
EOF
then
    echo ""
    success "Remote bootstrap completed successfully on $SSH_HOST"
    echo ""
    log "Next steps:"
    echo "  1. SSH into the server: ssh $SSH_HOST"
    echo "  2. Reload shell: exec fish"
    echo "  3. Verify configuration: fish --version"
else
    echo ""
    error "Remote bootstrap failed on $SSH_HOST"
    exit 1
fi
